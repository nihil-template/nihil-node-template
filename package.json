{
  "name": "nihil-node-template",
  "version": "1.0.0",
  "description": "노드 프로젝트 편하게 시작하려고 만든 템플릿. 타입스크립트 기본 지원.",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nihil-template/nihil-node-template.git"
  },
  "bugs": {
    "url": "https://github.com/nihil-template/nihil-node-template/issues"
  },
  "homepage": "https://github.com/nihil-template/nihil-node-template#readme",
  "scripts": {
    "start": "ts-node --respawn --transpile-only --no-notify -r tsconfig-paths/register src/index.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only --no-notify -r tsconfig-paths/register src/index.ts",
    "start:prod": "node -r tsconfig-paths/register build/index.js",
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [],
  "author": "NIHILncunia",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^17.0.21",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.13.0",
    "eslint": "^8.10.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-html": "^6.2.0",
    "eslint-plugin-import": "^2.25.4",
    "ts-node": "^10.6.0",
    "ts-node-dev": "^1.1.8",
    "tsconfig-paths": "^3.12.0",
    "typescript": "^4.6.2"
  }
}
