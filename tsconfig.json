{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "commonjs",
    "target": "es2015",
    "rootDir": "src",
    "outDir": "build",
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": [ "./src/**/*" ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
